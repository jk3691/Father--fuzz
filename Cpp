#include <jni.h>
#include <string>
#include <oboe/Oboe.h>
#include <android/log.h>

#define TAG "DarkFather-Fuzz"

class AudioEngine : public oboe::AudioStreamDataCallback {
public:
    void start() {
        oboe::AudioStreamBuilder builder;
        builder.setDirection(oboe::Direction::Output)
               ->setPerformanceMode(oboe::PerformanceMode::LowLatency)
               ->setSharingMode(oboe::SharingMode::Exclusive)
               ->setFormat(oboe::AudioFormat::Float)
               ->setChannelCount(oboe::ChannelCount::Mono)
               ->setCallback(this)
               ->openStream(mStream);

        if (mStream) {
            mStream->requestStart();
            __android_log_print(ANDROID_LOG_INFO, TAG, "Audio Stream Started");
        }
    }

    oboe::DataCallbackResult onAudioReady(oboe::AudioStream *oboeStream, void *audioData, int32_t numFrames) override {
        float *output = static_cast<float *>(audioData);
        for (int i = 0; i < numFrames; ++i) {
            // This is where your "fuzz" or synth logic goes
            output[i] = 0.0f; 
        }
        return oboe::DataCallbackResult::Continue;
    }

private:
    std::shared_ptr<oboe::AudioStream> mStream;
};

// JNI Interface to talk to your Android Kotlin/Java code
extern "C" JNIEXPORT void JNICALL
Java_com_example_fatherfuzz_MainActivity_startAudio(JNIEnv *env, jobject thiz) {
    static AudioEngine engine;
    engine.start();
}
